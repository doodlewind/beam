{
  "name": "beam-gpu",
  "version": "0.3.0",
  "description": "Expressive WebGPU — a tiny, teachable WebGPU library",
  "type": "module",
  "main": "./dist/beam-gpu.js",
  "module": "./dist/beam-gpu.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/beam-gpu.js"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["webgpu", "wgsl", "graphics", "shader", "gpu", "rendering"],
  "repository": "https://github.com/doodlewind/beam.git",
  "author": "Yifeng Wang",
  "license": "MIT",
  "devDependencies": {
    "@webgpu/types": "^0.1.49",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.6"
  }
}
